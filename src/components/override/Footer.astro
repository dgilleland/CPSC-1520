---
import Default from "@astrojs/starlight/components/Footer.astro";
---

<Default><slot /></Default>
<footer class="sl-flex not-content">
    <div class="meta sl-flex">
        <a class="sl-flex print:hidden" href="/CPSC-1520/legal/terms/">Terms</a> ·
        <a class="sl-flex print:hidden" href="/CPSC-1520/legal/privacy/">Privacy</a> ·
        <a class="sl-flex print:hidden" href="/CPSC-1520/legal/copyright/">Copyright</a>
    </div>
</footer>
<style>
        footer {
            flex-direction: column;
            gap: 0;
            margin-top: 0;
            padding-bottom: 1rem;
        }

        a {
            gap: 0.5rem;
            align-items: center;
            text-decoration: none;
            color: var(--sl-color-gray-3);
        }
        a:hover {
            color: var(--sl-color-white);
        }

        .meta {
            gap: 0.75rem 0.75rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 3rem;
            font-size: var(--sl-text-sm);
            color: var(--sl-color-gray-3);
        }
        .meta > :global(p:only-child) {
            margin-inline-start: auto;
        }
</style>
